generator client {
  provider = "prisma-client-js"
  // native = local dev; rhel-openssl-3.0.x = Vercel's serverless (AWS Lambda) runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
}

model MarketSource {
  id        String   @id
  title     String
  publisher String
  url       String   @unique
  date      String
  notes     String
  createdAt DateTime @default(now())
}

model Competitor {
  id             String   @id
  name           String
  category       String
  marketShare    Float
  growth         Float
  sentiment      Float
  engagement     Float
  revenueInrCr   Float?
  cities         Int?
  stores         Int?
  pricing        String
  moat           String
  fastestChannel String
  risk           String
  insight        String
  sourceId       String
  createdAt      DateTime @default(now())
}

model TrendSignal {
  id              String   @id
  period          String
  quickCommerce   Float
  premiumProducts Float
  festiveDemand   Float
  loyalty         Float
  sourceId        String
  createdAt       DateTime @default(now())
}

model CampaignPattern {
  id          String   @id
  brand       String
  name        String
  channel     String
  lift        String
  spend       String
  pattern     String
  whyItWorked String
  sourceId    String
  createdAt   DateTime @default(now())
}

model Recommendation {
  id         String   @id
  title      String
  impact     Int
  confidence Int
  motion     String
  action     String
  createdAt  DateTime @default(now())
}

model Run {
  id               String    @id @default(cuid())
  status           String    @default("pending")
  mode             String    @default("demo")
  market           String
  company          String
  region           String    @default("India")
  objective        String    @default("Find growth opportunities and campaign ideas")
  horizon          String    @default("30 days")
  competitorsJson  Json      @default("[]")
  executiveSummary String?
  insightsJson     Json?
  playsJson        Json?
  costUsd          Float?
  error            String?
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  createdAt        DateTime  @default(now())

  @@index([createdAt(sort: Desc)])
}

model Alert {
  id           String    @id @default(cuid())
  type         String    // growth_spike, market_share_change, new_campaign, sentiment_drop
  severity     String    @default("medium") // low, medium, high, critical
  competitor   String
  metric       String
  currentValue Float
  threshold    Float
  message      String
  isRead       Boolean   @default(false)
  isActive     Boolean   @default(true)
  triggeredAt  DateTime  @default(now())
  createdAt    DateTime  @default(now())

  @@index([triggeredAt(sort: Desc)])
  @@index([isRead])
}

model AlertRule {
  id          String   @id @default(cuid())
  name        String
  competitor  String   // competitor name or "any"
  metric      String   // growth, marketShare, sentiment, engagement
  operator    String   // gt, lt, eq, change_by
  threshold   Float
  severity    String   @default("medium")
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
