# OpenAI — required for live AI agents & chat. Leave OPENAI_API_KEY blank to run in demo mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Optional research providers — enable live market scans & richer source ingestion.
SERPAPI_API_KEY=
FIRECRAWL_API_KEY=
EXA_API_KEY=

# PostgreSQL connection (TCP). Replace USER/PASSWORD and create the DB first:
#   createdb vantageiq_local
# Local-socket alternative (no password):
#   postgresql://USER@localhost/vantageiq_local?host=%2Ftmp&schema=public
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/vantageiq_local?schema=public"

# Secret used to sign auth JWTs. Set a long random string in production.
#   e.g. openssl rand -hex 32
AUTH_JWT_SECRET=change-me-to-a-long-random-string

# API server port
PORT=8787

# How often (ms) the server auto-evaluates alert rules. Default 5 minutes.
ALERT_CHECK_INTERVAL_MS=300000

# Frontend override for the API base URL (defaults to http://127.0.0.1:8787).
# Set this when the web app and API run on different hosts/ports.
VITE_API_BASE_URL=
